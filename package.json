{
  "name": "@gaud_erp/papperclip_observability",
  "version": "0.3.3",
  "type": "module",
  "description": "Grafana and CloudWatch metrics in the Paperclip sidebar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gauderp/paperclip-plugin-observability.git"
  },
  "homepage": "https://github.com/gauderp/paperclip-plugin-observability#readme",
  "bugs": {
    "url": "https://github.com/gauderp/paperclip-plugin-observability/issues"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": ["paperclip", "plugin", "observability", "grafana", "cloudwatch"],
  "author": "Paperclip",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1052.0"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "2026.517.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
