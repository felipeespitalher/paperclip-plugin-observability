{
  "name": "@paperclip/observability",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Grafana and CloudWatch metrics in the Paperclip sidebar",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": ["paperclip", "plugin", "observability", "grafana", "cloudwatch"],
  "author": "Paperclip",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "2026.517.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
